<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Practico1" parent="Theme.MaterialComponents.Light.DarkActionBar">
        <item name="colorPrimary">@color/action_bar_dark</item>
        <item name="colorPrimaryDark">@color/action_bar_dark_status</item>
        <item name="colorPrimaryVariant">@color/action_bar_dark_status</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/button_gray</item>
        <item name="colorOnSecondary">@color/button_text</item>
        <item name="android:windowBackground">@color/form_background</item>
        <item name="android:statusBarColor">@color/action_bar_dark_status</item>
        <item name="actionBarStyle">@style/Widget.Practico1.ActionBar</item>
        <item name="actionBarTheme">@style/ThemeOverlay.Practico1.ActionBar</item>
    </style>

    <style name="ThemeOverlay.Practico1.ActionBar" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="android:textColorPrimary">@color/white</item>
    </style>

    <style name="Widget.Practico1.ActionBar" parent="Widget.MaterialComponents.Light.ActionBar.Solid">
        <item name="background">@color/action_bar_dark</item>
        <item name="titleTextStyle">@style/TextAppearance.Practico1.ActionBar.Title</item>
    </style>

    <style name="TextAppearance.Practico1.ActionBar.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Widget.Practico1.ClassicButton" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_classic</item>
        <item name="android:textColor">@color/button_text</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
